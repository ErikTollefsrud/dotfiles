# Hold my beverage...

# Config generated by Ghostty Config

shell-integration = zsh

window-save-state = always

# Font

font-family = "SF Mono Powerline"
font-feature = -calt, -liga, -dlig

# Colors and Theme

theme = Catppuccin Mocha

background = #1e1e2e
foreground = #cdd6f4

selection-background = #585b70
selection-foreground = #cdd6f4

split-divider-color = #FFE9AD

cursor-color = #f5e0dc
cursor-text = #1e1e2e
cursor-style = bar
cursor-style-blink = true

palette = 0=#45475a
palette = 1=#f38ba8
palette = 2=#a6e3a1
palette = 3=#f9e2af
palette = 4=#89b4fa
palette = 5=#f5c2e7
palette = 6=#94e2d5
palette = 7=#a6adc8
palette = 8=#585b70
palette = 9=#f37799
palette = 10=#89d88b
palette = 11=#ebd391
palette = 12=#74a8fc
palette = 13=#f2aede
palette = 14=#6bd7ca
palette = 15=#bac2de

# Mouse and Keyboard
mouse-hide-while-typing = true
macos-option-as-alt = true

# Keybindings
keybind = ctrl+\=new_split:right
keybind = ctrl+-=new_split:down

keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:down
keybind = ctrl+k=goto_split:up
keybind = ctrl+l=goto_split:right

keybind = alt+h=resize_split:left,10
keybind = alt+j=resize_split:down,10
keybind = alt+k=resize_split:up,10
keybind = alt+l=resize_split:right,10

keybind = ctrl+f=toggle_split_zoom

keybind = ctrl+x=close_surface

keybind = super+r=reload_config
# Check for Updates
auto-update = check
auto-update-channel = stable
